{
  "name": "@realmlabs/scon-typescript",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.base.json",
    "fuzz:parse": "pnpm build && jazzer packages/scon-core/fuzz/parse-string.mjs",
    "fuzz:format-source": "pnpm build && jazzer packages/scon-core/fuzz/format-source.mjs",
    "test": "pnpm build && node --test \"packages/*/test/*.test.js\"",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "devDependencies": {
    "@jazzer.js/core": "^4.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^6.0.3",
    "zod": "^4.1.0"
  }
}
